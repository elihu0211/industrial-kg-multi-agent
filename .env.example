# ── LLM Gateway（選一種）─────────────────────────────────────────────────────
# 方式 A：直接打 OpenAI（預設）
OPENAI_API_KEY=sk-...

# 方式 B：走 LiteLLM Proxy（api.ithu.tw）— 取消下面三行的註解並填入 master key
# OPENAI_BASE_URL=https://api.ithu.tw/v1
# OPENAI_API_KEY=sk-你的-master-key
# LLM_MODEL=gpt-oss-120b

# ── Agent URL ─────────────────────────────────────────────────────────────────
# Local dev: langgraph dev server (pnpm dev:agent starts it on :8123)
AGENT_URL=http://localhost:8123
# Deployed LangGraph Platform (overrides AGENT_URL if set)
# LANGGRAPH_DEPLOYMENT_URL=https://your-deployment.langchain.com

# ── CopilotKit Threads (optional) ─────────────────────────────────────────────
# Set this token to enable the multi-thread sidebar (ThreadsDrawer).
# Leave blank to use InMemoryAgentRunner (suitable for local dev).
# COPILOTKIT_LICENSE_TOKEN=

# Required when COPILOTKIT_LICENSE_TOKEN is set:
# INTELLIGENCE_API_KEY=
# INTELLIGENCE_API_URL=http://localhost:4201
# INTELLIGENCE_GATEWAY_WS_URL=ws://localhost:4401

# ── Observability (optional) ──────────────────────────────────────────────────
# LANGSMITH_API_KEY=

# ── MCP (optional) ────────────────────────────────────────────────────────────
# Custom MCP server URL. Defaults to https://mcp.excalidraw.com (demo).
# MCP_SERVER_URL=https://mcp.excalidraw.com
